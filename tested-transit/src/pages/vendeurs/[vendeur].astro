---
import { vendeurs, getVendeurBySlug } from '../../../data/vendeurs';

export function getStaticPaths() {
  return vendeurs.map((v) => ({ params: { vendeur: v.slug } }));
}

const { vendeur: slug } = Astro.params;
const vendeur = getVendeurBySlug(slug!);

if (!vendeur) return Astro.redirect('/404');

const anneeActuelle = new Date().getFullYear();
const anciennete = anneeActuelle - vendeur.depuis;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{vendeur.prenom} {vendeur.nom} — Ecocuisine</title>
    <meta name="description" content={`${vendeur.prenom} ${vendeur.nom}, ${vendeur.titre} chez Ecocuisine. ${vendeur.description.slice(0, 150)}...`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>
  <body>

    <!-- Header brand -->
    <header class="site-header">
      <div class="header-inner">
        <a href="https://ecocuisine.fr" class="brand">
          <span class="brand-eco">eco</span><span class="brand-cuisine">cuisine</span>
        </a>
        <span class="header-tag">Fiche conseiller</span>
      </div>
    </header>

    <main>

      <!-- Hero section -->
      <section class="hero">
        <div class="hero-bg"></div>
        <div class="hero-content">
          <div class="hero-photo-wrap">
            <img
              src={vendeur.photo}
              alt={`${vendeur.prenom} ${vendeur.nom}`}
              class="hero-photo"
              loading="eager"
            />
            <div class="anciennete-badge">
              <span class="anciennete-num">{anciennete}</span>
              <span class="anciennete-txt">ans chez<br/>Ecocuisine</span>
            </div>
          </div>
          <div class="hero-info">
            <p class="hero-depuis">Conseiller depuis {vendeur.depuis}</p>
            <h1 class="hero-nom">{vendeur.prenom}<br/><em>{vendeur.nom}</em></h1>
            <p class="hero-titre">{vendeur.titre}</p>
            <p class="hero-zone">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              {vendeur.zone}
            </p>
            <div class="specialites">
              {vendeur.specialites.map((s) => <span class="tag">{s}</span>)}
            </div>
            <div class="hero-cta">
              <a href={`tel:${vendeur.telephone}`} class="btn-primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12.1 19.79 19.79 0 0 1 1.61 3.52 2 2 0 0 1 3.6 1.35h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                Appeler
              </a>
              <a href={`mailto:${vendeur.email}`} class="btn-secondary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,12 2,6"/></svg>
                Écrire
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- Chiffres clés -->
      <section class="chiffres">
        <div class="chiffres-grid">
          {vendeur.chiffres.map((c) => (
            <div class="chiffre-item">
              <span class="chiffre-val">{c.valeur}</span>
              <span class="chiffre-label">{c.label}</span>
            </div>
          ))}
        </div>
      </section>

      <!-- À propos -->
      <section class="section about">
        <div class="container">
          <div class="section-label">À propos</div>
          <div class="about-grid">
            <div class="about-text">
              <h2 class="section-title">Une expertise<br/><em>au service de vos projets</em></h2>
              <p class="about-desc">{vendeur.description}</p>
            </div>
            <div class="certif-block">
              <h3 class="certif-title">Certifications & formations</h3>
              <ul class="certif-list">
                {vendeur.certifications.map((c) => (
                  <li class="certif-item">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    {c}
                  </li>
                ))}
              </ul>
              <div class="contact-card">
                <p class="contact-label">Contact direct</p>
                <a href={`tel:${vendeur.telephone}`} class="contact-line">{vendeur.telephone}</a>
                <a href={`mailto:${vendeur.email}`} class="contact-line">{vendeur.email}</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Réalisations -->
      <section class="section projets">
        <div class="container">
          <div class="section-label">Réalisations</div>
          <h2 class="section-title">Quelques projets<br/><em>emblématiques</em></h2>
          <div class="projets-grid">
            {vendeur.projets.map((p, i) => (
              <article class={`projet-card ${i === 0 ? 'projet-card--featured' : ''}`}>
                <div class="projet-img-wrap">
                  <img src={p.image} alt={p.titre} class="projet-img" loading="lazy" />
                  <span class="projet-annee">{p.annee}</span>
                </div>
                <div class="projet-body">
                  <h3 class="projet-titre">{p.titre}</h3>
                  <p class="projet-desc">{p.description}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- Avis clients -->
      <section class="section avis">
        <div class="container">
          <div class="section-label">Avis Google</div>
          <h2 class="section-title">Ce que disent<br/><em>nos clients</em></h2>
          <div class="avis-grid">
            {vendeur.avis.map((a) => (
              <article class="avis-card">
                <div class="avis-header">
                  <div class="avis-avatar">{a.auteur.charAt(0)}</div>
                  <div>
                    <p class="avis-auteur">{a.auteur}</p>
                    <div class="avis-etoiles">
                      {Array.from({ length: 5 }).map((_, i) => (
                        <svg width="14" height="14" viewBox="0 0 24 24" fill={i < a.note ? '#E8A838' : 'none'} stroke="#E8A838" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                      ))}
                    </div>
                  </div>
                  <span class="avis-date">{a.date}</span>
                </div>
                <p class="avis-texte">« {a.texte} »</p>
                <div class="google-badge">
                  <svg width="14" height="14" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                  Avis Google vérifié
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA final -->
      <section class="cta-final">
        <div class="container">
          <div class="cta-inner">
            <h2>Démarrez votre projet<br/>avec <em>{vendeur.prenom}</em></h2>
            <p>Prenez rendez-vous pour une visite à domicile gratuite et sans engagement.</p>
            <div class="cta-buttons">
              <a href={`tel:${vendeur.telephone}`} class="btn-primary btn-large">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12.1 19.79 19.79 0 0 1 1.61 3.52 2 2 0 0 1 3.6 1.35h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                {vendeur.telephone}
              </a>
              <a href={`mailto:${vendeur.email}`} class="btn-outline">Envoyer un message</a>
            </div>
          </div>
        </div>
      </section>

    </main>

    <!-- Footer -->
    <footer class="site-footer">
      <div class="container">
        <p>© {anneeActuelle} Ecocuisine — <span>{vendeur.prenom} {vendeur.nom}</span></p>
      </div>
    </footer>

  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --cream: #FAF7F2;
    --warm-white: #FFFEF9;
    --bark: #3D2B1A;
    --bark-light: #6B4C35;
    --sage: #7A9E7E;
    --sage-light: #B8D4BA;
    --gold: #C9943A;
    --gold-light: #E8C97A;
    --stone: #8E8078;
    --stone-light: #D4CCC4;
    --font-display: 'Playfair Display', Georgia, serif;
    --font-body: 'DM Sans', system-ui, sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--cream);
    color: var(--bark);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* ---- HEADER ---- */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250, 247, 242, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--stone-light);
  }
  .header-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 14px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .brand { text-decoration: none; font-size: 20px; font-weight: 500; letter-spacing: -0.02em; }
  .brand-eco { color: var(--sage); }
  .brand-cuisine { color: var(--bark); }
  .header-tag {
    font-size: 12px;
    color: var(--stone);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 500;
  }

  /* ---- HERO ---- */
  .hero {
    position: relative;
    background: var(--bark);
    min-height: 520px;
    overflow: hidden;
    display: flex;
    align-items: stretch;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 70% 50%, rgba(201,148,58,0.18) 0%, transparent 60%),
                radial-gradient(ellipse at 20% 80%, rgba(122,158,126,0.12) 0%, transparent 50%);
  }
  .hero-content {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    padding: 64px 24px;
    display: flex;
    align-items: center;
    gap: 56px;
    width: 100%;
  }
  .hero-photo-wrap {
    position: relative;
    flex-shrink: 0;
  }
  .hero-photo {
    width: 260px;
    height: 320px;
    object-fit: cover;
    border-radius: 4px 40px 4px 40px;
    display: block;
    filter: grayscale(10%) contrast(1.05);
  }
  .anciennete-badge {
    position: absolute;
    bottom: -16px;
    right: -16px;
    background: var(--gold);
    color: white;
    border-radius: 50%;
    width: 88px;
    height: 88px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }
  .anciennete-num {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    line-height: 1;
  }
  .anciennete-txt { font-size: 9.5px; font-weight: 500; line-height: 1.3; opacity: 0.9; }

  .hero-info { color: var(--cream); }
  .hero-depuis {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gold-light);
    font-weight: 500;
    margin-bottom: 10px;
  }
  .hero-nom {
    font-family: var(--font-display);
    font-size: clamp(38px, 6vw, 60px);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 10px;
  }
  .hero-nom em { font-style: italic; color: var(--gold-light); }
  .hero-titre {
    font-size: 16px;
    color: var(--stone-light);
    font-weight: 300;
    margin-bottom: 14px;
  }
  .hero-zone {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--sage-light);
    font-weight: 400;
    margin-bottom: 20px;
  }
  .specialites { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 32px; }
  .tag {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    color: var(--cream);
    padding: 5px 12px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 400;
  }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }

  /* ---- BUTTONS ---- */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--gold);
    color: white;
    padding: 12px 24px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 500;
    font-size: 14px;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-primary:hover { background: #b8832c; transform: translateY(-1px); }
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.25);
    color: white;
    padding: 12px 24px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 400;
    font-size: 14px;
    transition: background 0.2s;
  }
  .btn-secondary:hover { background: rgba(255,255,255,0.18); }
  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1.5px solid var(--bark);
    color: var(--bark);
    padding: 14px 28px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 500;
    font-size: 15px;
    transition: background 0.2s;
  }
  .btn-outline:hover { background: var(--bark); color: white; }
  .btn-large { padding: 16px 32px; font-size: 16px; }

  /* ---- CHIFFRES ---- */
  .chiffres {
    background: var(--bark);
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .chiffres-grid {
    max-width: 1100px;
    margin: 0 auto;
    padding: 40px 24px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }
  .chiffre-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 20px;
    border-right: 1px solid rgba(255,255,255,0.08);
    text-align: center;
  }
  .chiffre-item:last-child { border-right: none; }
  .chiffre-val {
    font-family: var(--font-display);
    font-size: 32px;
    font-weight: 700;
    color: var(--gold-light);
    line-height: 1;
  }
  .chiffre-label {
    font-size: 12px;
    color: var(--stone-light);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 6px;
    font-weight: 400;
  }

  /* ---- SECTIONS ---- */
  .section { padding: 80px 0; }
  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  .section-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 12px;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 600;
    line-height: 1.2;
    color: var(--bark);
    margin-bottom: 40px;
  }
  .section-title em { font-style: italic; color: var(--bark-light); font-weight: 400; }

  /* ---- ABOUT ---- */
  .about { background: var(--warm-white); }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 64px;
    align-items: start;
  }
  .about-desc {
    font-size: 17px;
    line-height: 1.8;
    color: var(--bark-light);
    font-weight: 300;
  }
  .certif-block {
    background: var(--cream);
    border-radius: 16px;
    padding: 32px;
    border: 1px solid var(--stone-light);
  }
  .certif-title {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--stone);
    font-weight: 600;
    margin-bottom: 20px;
  }
  .certif-list { list-style: none; display: flex; flex-direction: column; gap: 12px; margin-bottom: 28px; }
  .certif-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--bark);
    font-weight: 400;
  }
  .certif-item svg { color: var(--sage); flex-shrink: 0; }
  .contact-card {
    border-top: 1px solid var(--stone-light);
    padding-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .contact-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--stone);
    font-weight: 600;
    margin-bottom: 4px;
  }
  .contact-line {
    font-size: 14px;
    color: var(--bark);
    text-decoration: none;
    font-weight: 400;
    transition: color 0.2s;
  }
  .contact-line:hover { color: var(--gold); }

  /* ---- PROJETS ---- */
  .projets { background: var(--cream); }
  .projets-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .projet-card--featured {
    grid-column: span 2;
  }
  .projet-card {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--stone-light);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .projet-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(61,43,26,0.1); }
  .projet-img-wrap { position: relative; overflow: hidden; }
  .projet-img-wrap::after {
    content: '';
    display: block;
    padding-bottom: 62%;
  }
  .projet-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }
  .projet-card:hover .projet-img { transform: scale(1.04); }
  .projet-annee {
    position: absolute;
    top: 12px;
    right: 12px;
    background: rgba(61,43,26,0.8);
    color: var(--gold-light);
    font-size: 12px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 100px;
    letter-spacing: 0.05em;
    backdrop-filter: blur(4px);
  }
  .projet-body { padding: 24px; }
  .projet-titre {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 600;
    color: var(--bark);
    margin-bottom: 8px;
    line-height: 1.3;
  }
  .projet-desc {
    font-size: 14px;
    color: var(--stone);
    line-height: 1.6;
    font-weight: 300;
  }

  /* ---- AVIS ---- */
  .avis { background: var(--warm-white); }
  .avis-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .avis-card {
    background: white;
    border-radius: 16px;
    padding: 28px;
    border: 1px solid var(--stone-light);
    display: flex;
    flex-direction: column;
    gap: 16px;
    transition: box-shadow 0.2s;
  }
  .avis-card:hover { box-shadow: 0 8px 24px rgba(61,43,26,0.08); }
  .avis-header {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .avis-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--bark);
    color: var(--gold-light);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    flex-shrink: 0;
  }
  .avis-auteur { font-weight: 500; font-size: 14px; color: var(--bark); }
  .avis-etoiles { display: flex; gap: 2px; margin-top: 3px; }
  .avis-date {
    margin-left: auto;
    font-size: 12px;
    color: var(--stone);
    white-space: nowrap;
    align-self: flex-start;
  }
  .avis-texte {
    font-size: 14px;
